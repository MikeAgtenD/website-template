# ─── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Payload CMS ──────────────────────────────────────────────────────────────
# Generate a strong random secret for production
PAYLOAD_SECRET=change-me-to-a-strong-random-secret-in-production

# SQLite is the default (zero-config, great for development).
# For production, switch to @payloadcms/db-postgres or @payloadcms/db-mongodb
# and update payload.config.ts accordingly.
DATABASE_URI=file:./payload.db

# ─── Contact form mail (SMTP) ─────────────────────────────────────────────────
# Development default routes to Digital Horizon inbox.
# Replace with client SMTP credentials before going live.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=noreply@yourdomain.be
MAIL_TO=digitalhorizonservice@gmail.com
